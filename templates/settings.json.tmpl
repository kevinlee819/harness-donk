{
  "statusLine": {
    "type": "command",
    "command": "{{HARNESS_HOME}}/bin/harness statusline",
    "refreshInterval": 5
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit|Read",
        "hooks": [
          {
            "type": "command",
            "command": "{{HARNESS_HOME}}/hooks/pre_tool_use.sh"
          }
        ]
      }
    ]
  }
}
