#!/usr/bin/env bash
# harness-infi — 用户唯一入口
#
# 在当前 harness 项目目录内：
#   1. 复用或创建 tmux 会话 `harness-<sha8(pwd)>`
#   2. window 0 (main):
#        左 pane (60%): 交互式 claude，coordinator.md 注入 system prompt
#        右 pane (40%): harness watch TUI（任务列表 + worker 详情 + 协调者动作）
#                      终端窄于 120 列时退化为底部 18% 横向分割跑旧 watch-panel
#   3. window 1 (orchestrator): 后台执行平面，长跑 orchestrator.sh
#   4. window 2 (watchdog): 60s 心跳巡检
#   5. attach 到 main window；左右键切 pane 用 Alt-1 / Alt-2（无需 tmux prefix）
#      切窗口：Alt-0 main / Alt-o orchestrator / Alt-w watchdog
#      唤起活动日志覆盖层：Alt-l（display-popup，需 tmux ≥ 3.2）
#
# 选项：
#   --no-attach        创建会话但不 attach（脚本/CI 用）
#   --backend NAME     orchestrator 用哪个写者 backend（默 claude）
#   --model NAME       orchestrator 透传给 adapter（如 claude-sonnet-4-6）
#
# 见 docs/interfaces.md §1.1, CLAUDE.md §1 / §2 「唯一入口」原则。

set -uo pipefail

_resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do src="$(readlink "$src")"; done
  cd "$(dirname "$src")" && pwd
}
HARNESS_HOME="${HARNESS_HOME:-$(cd "$(_resolve_script_dir)/.." && pwd)}"
export HARNESS_HOME

cwd=$(pwd)
NO_ATTACH=0
BACKEND="claude"
MODEL=""

# Per-project config (written by 'harness init') overrides hardcoded default.
# CLI --backend still takes highest priority and is applied below.
if [[ -f "$cwd/.harness/config" ]]; then
  _proj_backend=$(grep '^backend=' "$cwd/.harness/config" 2>/dev/null | head -1 | cut -d= -f2-)
  [[ -n "$_proj_backend" ]] && BACKEND="$_proj_backend"
fi

while [[ $# -gt 0 ]]; do
  case "$1" in
    --no-attach) NO_ATTACH=1; shift ;;
    --backend) BACKEND="$2"; shift 2 ;;
    --model)   MODEL="$2"; shift 2 ;;
    -h|--help) sed -n '2,18p' "$0"; exit 0 ;;
    *) echo "unknown arg: $1" >&2; exit 1 ;;
  esac
done

# ── 前置检查 ──
if [[ ! -f "$cwd/.harness/harness.db" ]]; then
  echo "error: not a harness project (no .harness/harness.db)" >&2
  echo "       run: harness init" >&2
  exit 1
fi

for bin in tmux claude; do
  if ! command -v "$bin" >/dev/null 2>&1; then
    echo "error: $bin not found on PATH" >&2
    [[ "$bin" == "claude" ]] && echo "       run: harness doctor" >&2
    exit 2
  fi
done

coord_md="$HARNESS_HOME/coordinator/coordinator.md"
if [[ ! -f "$coord_md" ]]; then
  echo "error: coordinator system prompt missing: $coord_md" >&2
  exit 2
fi

if [[ ! -f "$HARNESS_HOME/adapters/${BACKEND}.sh" ]]; then
  echo "error: unknown backend: $BACKEND (no adapters/${BACKEND}.sh)" >&2
  exit 2
fi

# ── 会话名：harness-<sha8(pwd)> ──
hash=$(printf '%s' "$cwd" | shasum -a 256 | cut -c1-8)
session="harness-$hash"

# ── 已存在则直接 attach（不重建 window，保留用户当前状态）──
if tmux has-session -t "$session" 2>/dev/null; then
  [[ $NO_ATTACH -eq 1 ]] && { echo "session $session already exists"; exit 0; }
  exec tmux attach -t "$session"
fi

# ── 准备 launcher 脚本：避开 shell 引号灾难 ──
# coordinator: claude 交互式 + coordinator.md system prompt
coord_launcher="$cwd/.harness/.coordinator-launcher.sh"
# Detect if this is a fresh project (idea file exists, no tasks yet)
_has_initial_idea=0
[[ -f "$cwd/specs/initial.md" ]] && _has_initial_idea=1

cat > "$coord_launcher" <<EOF
#!/usr/bin/env bash
set -uo pipefail
export HARNESS_HOME='$HARNESS_HOME'
export HARNESS_DB='$cwd/.harness/harness.db'
export PATH='$HARNESS_HOME/coordinator/tools:$HARNESS_HOME/bin':"\$PATH"

# ── Welcome banner (shown before Claude Code takes over the screen) ──
printf "\033[2J\033[H"  # clear screen
printf "\033[1m🫏 harness-donk\033[0m  ·  $(basename "$cwd")\n"
printf "\033[2m────────────────────────────────────────────\033[0m\n"
EOF

if [[ $_has_initial_idea -eq 1 ]]; then
  cat >> "$coord_launcher" <<'INNEREOF'
idea=$(grep -Ev '^#|^---|^$|^\*' specs/initial.md 2>/dev/null | head -1 | cut -c1-60)
printf "  \033[2m💡 your idea:\033[0m  %s\n" "$idea"
printf "\n"
printf "  \033[32mClaude is loading — say hi or just press Enter ↓\033[0m\n"
INNEREOF
else
  cat >> "$coord_launcher" <<'INNEREOF'
printf "  \033[32mClaude is loading — tell it what you want to build ↓\033[0m\n"
INNEREOF
fi

cat >> "$coord_launcher" <<EOF
printf "\033[2m────────────────────────────────────────────\033[0m\n\n"
exec claude --append-system-prompt "\$(cat '$coord_md')"
EOF
chmod +x "$coord_launcher"

# watch TUI: the new interactive dashboard. Auto-restarts if user accidentally
# quits with `q` so the pane never goes silent. Falls back to the old looping
# watch-panel only if the curses TUI exits immediately (e.g. terminal lacks
# unicode support); see watch_tui.py:_show_help for keybindings.
panel_launcher="$cwd/.harness/.panel-launcher.sh"
cat > "$panel_launcher" <<EOF
#!/usr/bin/env bash
set -uo pipefail
export HARNESS_HOME='$HARNESS_HOME'
export HARNESS_DB='$cwd/.harness/harness.db'
export PATH='$HARNESS_HOME/coordinator/tools:$HARNESS_HOME/bin':"\$PATH"
cd '$cwd'
while true; do
  # The TUI handles its own clear + redraw loop. We just wrap-and-restart so
  # accidentally pressing 'q' brings it back rather than leaving a dead pane.
  '$HARNESS_HOME/bin/harness' watch 2>/dev/null || {
    # Curses failed (no TERM, ancient terminal, etc.) — fall back to snapshot.
    clear
    '$HARNESS_HOME/bin/harness' watch-panel 2>/dev/null \
      || printf "🫏  initializing…\n"
    sleep 5
    continue
  }
  # User pressed q — show a hint and wait briefly before respawning.
  printf "\n  \033[2m(press Enter to reopen, Ctrl-C to leave the pane dead)\033[0m\n"
  read -r _ || break
done
EOF
chmod +x "$panel_launcher"

# orchestrator: 长跑 orchestrator.sh（无 --once）
# 死循环 + sleep 5s 在 queue 空时；任务来了立刻派
orch_launcher="$cwd/.harness/.orchestrator-launcher.sh"
cat > "$orch_launcher" <<EOF
#!/usr/bin/env bash
# 协调者会话的伴生执行平面：长跑 orchestrator.sh。
# 异常退出后 tmux 会保留 pane（remain-on-exit on），便于排障。
set -uo pipefail
export HARNESS_HOME='$HARNESS_HOME'
cd '$cwd'
echo "🫏 harness-donk — multi-agent self-driving coding harness"
echo "─────────────────────────────────────────────────────"
echo "[infi] orchestrator daemon starting (backend=$BACKEND model=${MODEL:-default})"
echo "[infi] cwd=$cwd  log=.harness/logs/raw/"
echo "[infi] Ctrl-C to stop; 'harness-task add' from window 0 to enqueue"
echo
exec bash '$HARNESS_HOME/orchestrator.sh' --backend '$BACKEND'${MODEL:+ --model '$MODEL'}
EOF
chmod +x "$orch_launcher"

# watchdog: 每 10 分钟巡检一次，检测 orchestrator 自身挂掉等场景，发桌面通知
watchdog_launcher="$cwd/.harness/.watchdog-launcher.sh"
cat > "$watchdog_launcher" <<EOF
#!/usr/bin/env bash
set -uo pipefail
export HARNESS_HOME='$HARNESS_HOME'
cd '$cwd'
exec '$HARNESS_HOME/bin/harness-watchdog' '$cwd'
EOF
chmod +x "$watchdog_launcher"

# ── 创建会话：window 0 = main (coord + watch), 1 = orchestrator, 2 = watchdog ──
tmux new-session -d -s "$session" -c "$cwd" -n main "$coord_launcher"
tmux set-option -t "$session" remain-on-exit on >/dev/null 2>&1 || true

# Decide split orientation based on outer terminal width. The watch TUI needs
# ≥60 cols, and Claude's prompt + thinking output needs ≥80 to read comfortably.
# A vertical (left/right) split needs ~140 to give both sides enough breathing
# room; below that we fall back to the legacy horizontal (top/bottom) layout
# so neither pane is unusable.
term_w=$(tput cols 2>/dev/null || echo 80)
if (( term_w >= 140 )); then
  # Vertical split: coordinator left ~60%, watch TUI right ~40%
  tmux split-window -t "$session:0" -h -p 40 -c "$cwd" "$panel_launcher" 2>/dev/null || true
else
  # Horizontal split: coordinator top ~70%, watch TUI bottom ~30%
  tmux split-window -t "$session:0" -v -p 30 -c "$cwd" "$panel_launcher" 2>/dev/null || true
fi
tmux select-pane -t "$session:0.0"   # focus the coordinator pane

tmux new-window -t "$session" -c "$cwd" -n orchestrator "$orch_launcher"
tmux new-window -t "$session" -c "$cwd" -n watchdog     "$watchdog_launcher"

# Per-session keybindings — applied via if-shell so they only fire when the
# user's active session matches ours. No-prefix Alt keys for pane/window nav:
#   Alt-1 / Alt-2  → focus left / right pane in window 0
#   Alt-0           → jump back to window 0 (main)
#   Alt-o / Alt-w   → orchestrator / watchdog window
#   Alt-r           → in watch pane: tell the TUI to refresh (sends 'r' is
#                     ambiguous with retry; skip and rely on TUI's 1s tick)
# bind-key -n applies server-wide; the if-shell guard checks session name.
_guard="[ \"#{session_name}\" = \"$session\" ]"
tmux bind-key -n M-1 if-shell "$_guard" "select-pane -t :.0" "send-keys M-1" 2>/dev/null || true
tmux bind-key -n M-2 if-shell "$_guard" "select-pane -t :.1" "send-keys M-2" 2>/dev/null || true
tmux bind-key -n M-0 if-shell "$_guard" "select-window -t :0" "send-keys M-0" 2>/dev/null || true
tmux bind-key -n M-o if-shell "$_guard" "select-window -t :orchestrator" "send-keys M-o" 2>/dev/null || true
tmux bind-key -n M-w if-shell "$_guard" "select-window -t :watchdog"     "send-keys M-w" 2>/dev/null || true
# M-l opens the activity-log viewer in a popup (tmux ≥ 3.2). The popup overlays
# the current pane; press 'q' inside to dismiss. Falls back silently on
# older tmux versions.
tmux bind-key -n M-l if-shell "$_guard" \
  "display-popup -E -h 80% -w 80% -d '$cwd' '$HARNESS_HOME/bin/harness' activity" \
  "send-keys M-l" 2>/dev/null || true

tmux select-window -t "$session:0"

if [[ $NO_ATTACH -eq 1 ]]; then
  echo "session $session created (windows: main + orchestrator + watchdog)"
  echo "attach: tmux attach -t $session"
  exit 0
fi

exec tmux attach -t "$session"
