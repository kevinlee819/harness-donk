#!/usr/bin/env bash
# harness — 管理/观测 CLI
# 见 docs/interfaces.md §1.2
#
# bash 仅负责"调命令"；DB 操作全部走 python -m harness.cli.db_cli。
# 语言边界见 CLAUDE.md §8 / §4.9。

set -uo pipefail

_resolve_script_dir() {
  local src="${BASH_SOURCE[0]}"
  while [[ -L "$src" ]]; do src="$(readlink "$src")"; done
  cd "$(dirname "$src")" && pwd
}
HARNESS_HOME="${HARNESS_HOME:-$(cd "$(_resolve_script_dir)/.." && pwd)}"
export HARNESS_HOME
source "$HARNESS_HOME/lib/python_env.sh"

_db() { "$HARNESS_PYTHON" -m harness.cli.db_cli "$@"; }

# ── project-type detection helpers ───────────────────────
_detect_project_type() {
  [[ -f pyproject.toml || -f requirements.txt || -f setup.py ]] && echo python && return
  [[ -f package.json ]] && echo node && return
  [[ -f go.mod ]] && echo go && return
  [[ -f Cargo.toml ]] && echo rust && return
  [[ -f pom.xml || -f build.gradle || -f build.gradle.kts ]] && echo java && return
  [[ -f Gemfile ]] && echo ruby && return
  echo unknown
}

_gate_defaults() {
  local type="$1"
  local test_cmd="" lint_cmd="" build_cmd=""
  case "$type" in
    python)
      test_cmd="pytest"
      grep -qs "ruff" pyproject.toml 2>/dev/null && lint_cmd="ruff check ." || lint_cmd="flake8"
      ;;
    node)
      # Always seed with standard npm conventions; override only if package.json
      # exists but is missing that specific script (then blank it out).
      test_cmd="npm test"; lint_cmd="npm run lint"; build_cmd="npm run build"
      if [[ -f package.json ]]; then
        jq -e '.scripts.test'  package.json &>/dev/null || test_cmd=""
        jq -e '.scripts.lint'  package.json &>/dev/null || lint_cmd=""
        jq -e '.scripts.build' package.json &>/dev/null || build_cmd=""
      fi
      ;;
    go)   test_cmd="go test ./..."; build_cmd="go build ./..."; lint_cmd="go vet ./..." ;;
    rust) test_cmd="cargo test";    build_cmd="cargo build";    lint_cmd="cargo clippy" ;;
    ruby) test_cmd="bundle exec rspec"; lint_cmd="bundle exec rubocop" ;;
  esac
  echo "test=$test_cmd"
  echo "lint=$lint_cmd"
  echo "build=$build_cmd"
}

_count_project_files() {
  find . -maxdepth 3 -type f \
    ! -path './.git/*' ! -name '.gitignore' ! -name 'README.md' \
    ! -name 'LICENSE' ! -name '.DS_Store' 2>/dev/null | wc -l | tr -d ' '
}

cmd="${1:-help}"; shift || true

cmd_init() {
  local cwd; cwd=$(pwd)
  local writer="claude"
  local reviewer=""
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --backend)  writer="$2";   shift 2 ;;
      --reviewer) reviewer="$2"; shift 2 ;;
      *) shift ;;
    esac
  done

  # ── 1. ensure git repo ───────────────────────────────────
  if [[ ! -d "$cwd/.git" ]]; then
    echo "No git repository found — initializing one." >&2
    git init -q
  fi
  # worktrees need at least one commit
  if ! git rev-parse HEAD &>/dev/null; then
    git -c commit.gpgsign=false commit -q --allow-empty -m "init"
  fi

  if [[ -f "$cwd/.harness/harness.db" ]]; then
    echo "already initialized" >&2; return 0
  fi

  # ── 2. detect project type & gate defaults ───────────────
  local proj_type; proj_type=$(_detect_project_type)
  local nfiles;    nfiles=$(_count_project_files)
  local test_cmd="" lint_cmd="" build_cmd="" project_idea=""

  while IFS='=' read -r _k _v; do
    case "$_k" in test) test_cmd="$_v" ;; lint) lint_cmd="$_v" ;; build) build_cmd="$_v" ;; esac
  done < <(_gate_defaults "$proj_type")

  # ── 3. interactive setup (only when stdin is a TTY) ──────
  if [[ -t 0 ]]; then
    # ── 选执行 agent 和审查 agent ─────────────────────────
    echo ""
    echo "执行 agent（负责写代码的 worker）："
    echo "  1) claude  （推荐，自带文件编辑工具）"
    echo "  2) codex   （OpenAI Codex CLI）"
    read -r -p "  [1]: " _c
    case "${_c:-1}" in
      2|codex) writer="codex" ;;
      *)       writer="claude" ;;
    esac

    echo ""
    echo "审查 agent（cross-review，建议与 writer 不同模型）："
    if [[ "$writer" == "claude" ]]; then
      echo "  1) codex   （推荐）"
      echo "  2) claude  （同模型，效果较弱）"
      echo "  3) 跳过    （关闭 cross_review）"
      read -r -p "  [1]: " _c
      case "${_c:-1}" in
        2|claude) reviewer="claude" ;;
        3|skip)   reviewer="none" ;;
        *)        reviewer="codex" ;;
      esac
    else
      echo "  1) claude  （推荐）"
      echo "  2) codex   （同模型，效果较弱）"
      echo "  3) 跳过    （关闭 cross_review）"
      read -r -p "  [1]: " _c
      case "${_c:-1}" in
        2|codex) reviewer="codex" ;;
        3|skip)  reviewer="none" ;;
        *)       reviewer="claude" ;;
      esac
    fi

    if [[ "$nfiles" -lt 3 && "$proj_type" == unknown ]]; then
      # PATH A: brand-new empty project — just capture the idea, hand off to AI
      echo ""
      echo "这是一个新项目。"
      echo ""
      read -r -p "你想做什么？（一句话描述）: " project_idea
    else
      # PATH B: existing project — auto-detect gate, coordinator verifies on first run
      echo ""
      [[ "$proj_type" != unknown ]] && echo "检测到：$proj_type 项目。"
      if [[ -n "${build_cmd}${lint_cmd}${test_cmd}" ]]; then
        echo "Gate 命令（自动检测；协调者首次运行时会验证/更新）："
        printf "  build: %s\n" "${build_cmd:-(none)}"
        printf "  lint:  %s\n" "${lint_cmd:-(none)}"
        printf "  test:  %s\n" "${test_cmd:-(none)}"
      else
        echo "未检测到标准 gate 命令 — 协调者会在分析项目后自动配置。"
      fi
    fi
  fi
  # non-interactive: silently apply detected defaults

  # apply reviewer default if still unset (non-interactive or --backend only)
  if [[ -z "$reviewer" ]]; then
    case "$writer" in
      claude) reviewer="codex" ;;
      *)      reviewer="claude" ;;
    esac
  fi

  # ── 4. scaffold .harness/ ────────────────────────────────
  mkdir -p "$cwd/.harness/workers" "$cwd/.harness/inbox" "$cwd/.harness/events" \
           "$cwd/.harness/logs/raw" "$cwd/specs"
  export HARNESS_DB="$cwd/.harness/harness.db"
  _db init || { echo "db init failed" >&2; exit 1; }
  # persist backend choice so harness-infi picks it up without --backend flag
  printf 'backend=%s\nreviewer=%s\n' "$writer" "$reviewer" > "$cwd/.harness/config"

  # ── 5. generate AGENTS.md with gate config filled in ─────
  local lang="${HARNESS_LANG:-en}"
  local tmpl_dir="$HARNESS_HOME/templates/$lang"
  [[ -d "$tmpl_dir" ]] || tmpl_dir="$HARNESS_HOME/templates"

  if [[ ! -f "$cwd/AGENTS.md" ]]; then
    # reviewer="none" → keep placeholder reviewer value but enabled stays false
    local _agents_reviewer="$reviewer"
    [[ "$_agents_reviewer" == "none" ]] && _agents_reviewer="codex"
    sed -e "s/{{PROJECT_NAME}}/$(basename "$cwd")/g" \
        -e "s/^cross_review_reviewer: codex$/cross_review_reviewer: $_agents_reviewer/" \
        -e "s#build: \"\"#build: \"${build_cmd}\"#" \
        -e "s#lint: \"\"#lint: \"${lint_cmd}\"#" \
        -e "s#test: \"\"#test: \"${test_cmd}\"#" \
        "$tmpl_dir/AGENTS.md.tmpl" > "$cwd/AGENTS.md"
  fi
  [[ ! -L "$cwd/CLAUDE.md" && ! -f "$cwd/CLAUDE.md" ]] && ln -s AGENTS.md "$cwd/CLAUDE.md"

  mkdir -p "$cwd/docs"
  for kf in decisions error-journal; do
    if [[ ! -f "$cwd/docs/${kf}.md" ]]; then
      cp "$tmpl_dir/${kf}.md.tmpl" "$cwd/docs/${kf}.md"
    fi
  done

  if ! grep -q '^\.harness/' "$cwd/.gitignore" 2>/dev/null; then
    cat "$HARNESS_HOME/templates/gitignore-fragment" >> "$cwd/.gitignore"
  fi

  mkdir -p "$cwd/.claude"
  local settings_path="$cwd/.claude/settings.json"
  local rendered
  rendered=$(sed "s|{{HARNESS_HOME}}|$HARNESS_HOME|g" "$HARNESS_HOME/templates/settings.json.tmpl")
  if [[ ! -f "$settings_path" ]]; then
    printf '%s\n' "$rendered" > "$settings_path"
  else
    printf '%s\n' "$rendered" > "$settings_path.harness-suggested"
    echo "WARNING: .claude/settings.json exists; suggested hooks written to .claude/settings.json.harness-suggested — merge manually" >&2
  fi

  local conf_dir="${HARNESS_CONFIG_DIR:-$HOME/.config/harness}"
  mkdir -p "$conf_dir"
  local plist="$conf_dir/projects.list"
  touch "$plist"
  if ! grep -qxF "$cwd" "$plist"; then
    echo "$cwd" >> "$plist"
  fi

  # ── 6. save initial idea as first spec ───────────────────
  if [[ -n "$project_idea" ]]; then
    printf '# Initial Idea\n\n%s\n\n---\n*Created by `harness init`*\n' \
      "$project_idea" > "$cwd/specs/initial.md"
    echo "saved your idea to specs/initial.md"
  fi

  # ── 7. commit scaffold so worktrees inherit them ─────────
  # Workers branch from main. If scaffold files (AGENTS.md, .gitignore, etc.)
  # are untracked in main but committed on a worker branch, git merge fails with
  # "untracked files would be overwritten". Committing them now prevents this.
  (
    cd "$cwd"
    _scaffold=()
    [[ -f AGENTS.md ]]             && _scaffold+=(AGENTS.md)
    [[ -L CLAUDE.md || -f CLAUDE.md ]] && _scaffold+=(CLAUDE.md)
    [[ -f .gitignore ]]            && _scaffold+=(.gitignore)
    [[ -f docs/decisions.md ]]     && _scaffold+=(docs/decisions.md)
    [[ -f docs/error-journal.md ]] && _scaffold+=(docs/error-journal.md)
    [[ -f specs/initial.md ]]      && _scaffold+=(specs/initial.md)
    if [[ ${#_scaffold[@]} -gt 0 ]]; then
      git add "${_scaffold[@]}" 2>/dev/null || true
      if ! git diff --cached --quiet 2>/dev/null; then
        git -c commit.gpgsign=false commit -q -m "harness: scaffold" 2>/dev/null \
          && echo "committed scaffold files to git"
      fi
    fi
  )

  echo ""
  echo "harness initialized in $cwd"

  # When the wizard captured a project idea, hand off to harness-infi immediately
  # so the coordinator can continue the conversation.
  if [[ -n "$project_idea" && -t 0 ]]; then
    echo "Starting harness-infi — the coordinator will pick up your idea from specs/initial.md."
    echo "(Ctrl-C now to cancel and start manually later)"
    sleep 2
    exec "$HARNESS_HOME/bin/harness-infi"
  else
    echo "next: run 'harness-infi' to start"
    [[ -z "$test_cmd$lint_cmd$build_cmd" ]] && \
      echo "tip:  edit AGENTS.md to fill in gate commands (test/lint/build)"
  fi
}

cmd_status() {
  local cwd; cwd=$(pwd)
  export HARNESS_DB="$cwd/.harness/harness.db"
  [[ ! -f "$HARNESS_DB" ]] && { echo "not initialized" >&2; exit 1; }

  local task_id="" history=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --task) task_id="$2"; shift 2 ;;
      --history) history=1; shift ;;
      *) echo "unknown arg: $1" >&2; exit 1 ;;
    esac
  done

  # --task <id> [--history]：单任务详情 + 可选迁移史
  if [[ -n "$task_id" ]]; then
    local row
    row=$(_db query-status "$task_id")
    if [[ -z "$row" ]]; then
      echo "no such task: $task_id" >&2
      exit 1
    fi
    IFS=$'\t' read -r id stat wid branch retries reds prio created <<<"$row"
    printf "ID       : %s\n" "$id"
    printf "Status   : %s\n" "$stat"
    printf "Worker   : %s\n" "${wid:--}"
    printf "Branch   : %s\n" "${branch:--}"
    printf "Retries  : %s\n" "$retries"
    printf "Redispatches: %s\n" "$reds"
    printf "Priority : %s\n" "$prio"
    printf "Created  : %s\n" "$created"

    if [[ $history -eq 1 ]]; then
      echo
      echo "== History =="
      printf "  %-21s %-12s %-12s %s\n" "TIMESTAMP" "FROM" "TO" "REASON"
      _db query-history "$task_id" | while IFS=$'\t' read -r ts fs ts2 reason; do
        printf "  %-21s %-12s %-12s %s\n" "$ts" "${fs:--}" "$ts2" "${reason:--}"
      done
    fi
    return 0
  fi

  # 默认：全部任务摘要
  echo "== Today cost =="
  printf "  \$%.4f\n" "$(_db today-cost)"
  echo
  echo "== Tasks =="
  printf "  %-20s %-12s %-8s %-30s %s\n" "ID" "STATUS" "RETRIES" "BRANCH" "CREATED"
  _db query-status | while IFS=$'\t' read -r id stat wid branch retries reds prio created; do
    printf "  %-20s %-12s %-8s %-30s %s\n" "$id" "$stat" "$retries" "${branch:--}" "$created"
  done

  # 待处理事件计数
  local pending; pending=$(_db event-pending | wc -l | tr -d ' ')
  if [[ "$pending" != "0" ]]; then
    echo
    printf "== Pending events: %s ==\n" "$pending"
    _db event-pending | while IFS=$'\t' read -r eid ts etype tid payload; do
      printf "  #%-4s %s %-16s task=%-12s\n" "$eid" "$ts" "$etype" "${tid:--}"
    done
  fi
}

cmd_backup() {
  local cwd; cwd=$(pwd)
  local db_path="$cwd/.harness/harness.db"
  [[ ! -f "$db_path" ]] && { echo "not initialized" >&2; exit 1; }
  local out_dir="$cwd/.harness/backups"
  mkdir -p "$out_dir"
  local ts; ts=$(date -u +%Y%m%dT%H%M%SZ)
  local out="$out_dir/harness-$ts.db"
  # sqlite3 .backup 是在线热备份（持锁短，WAL 仍可读），比直接 cp 安全
  sqlite3 "$db_path" ".backup '$out'" || { echo "backup failed" >&2; exit 2; }

  # 保留策略：删除 N 天前的备份（默认 7 天，可通过 HARNESS_BACKUP_RETAIN_DAYS 覆盖）。
  # 至少保留最近 1 份，防 retain_days 过小把全部干掉。
  local retain="${HARNESS_BACKUP_RETAIN_DAYS:-7}"
  if [[ "$retain" =~ ^[0-9]+$ ]] && [[ "$retain" -gt 0 ]]; then
    local recent; recent=$(ls -1t "$out_dir"/harness-*.db 2>/dev/null | head -1)
    find "$out_dir" -name 'harness-*.db' -type f -mtime "+$retain" \
      ! -path "$recent" -delete 2>/dev/null || true
  fi

  echo "$out"
}

cmd_run_once() {
  local cwd; cwd=$(pwd)
  bash "$HARNESS_HOME/orchestrator.sh" --once --project "$cwd" "$@"
}

# ── setup：一次性环境校验 + 全局配置目录 ──
cmd_setup() {
  local rc=0
  echo "== Checking dependencies =="

  _check() {
    local name="$1"; local cmd="$2"; local minver="${3:-}"
    if ! command -v "$cmd" >/dev/null 2>&1; then
      printf "  ✗ %-12s %s not found on PATH\n" "$name" "$cmd"
      rc=2; return
    fi
    local ver
    case "$cmd" in
      sqlite3) ver=$("$cmd" --version 2>/dev/null | awk '{print $1}') ;;
      *)       ver=$("$cmd" --version 2>/dev/null | head -1) ;;
    esac
    printf "  ✓ %-12s %s\n" "$name" "$ver"
  }

  _check sqlite3 sqlite3
  _check jq      jq
  _check git     git
  _check tmux    tmux
  _check python3 "$HARNESS_PYTHON"

  # sqlite3 必须 ≥ 3.35（RETURNING）
  local sv
  if command -v sqlite3 >/dev/null 2>&1; then
    sv=$(sqlite3 --version | awk '{print $1}')
    local major=${sv%%.*}; local rest=${sv#*.}; local minor=${rest%%.*}
    if (( major < 3 || ( major == 3 && minor < 35 ) )); then
      echo "  ✗ sqlite3 $sv < 3.35 (RETURNING required)" >&2
      rc=2
    fi
  fi

  # 全局配置目录
  local conf_dir="${HARNESS_CONFIG_DIR:-$HOME/.config/harness}"
  if [[ ! -d "$conf_dir" ]]; then
    mkdir -p "$conf_dir"
    echo "  ✓ created $conf_dir"
  fi
  [[ ! -f "$conf_dir/projects.list" ]] && touch "$conf_dir/projects.list"
  if [[ ! -f "$conf_dir/config" ]]; then
    cat > "$conf_dir/config" <<EOF
# harness 全局配置（首次自动生成）
budget_daily_usd=10
session_resume_cap=6
dead_worker_threshold_min=10
blocked_timeout_hours=72
EOF
    echo "  ✓ wrote default $conf_dir/config"
  fi

  echo
  if [[ $rc -eq 0 ]]; then
    echo "ALL OK ✓"
  else
    echo "FAILED (rc=$rc)" >&2
  fi
  return $rc
}

# ── doctor：各 backend echo 自检 ──
cmd_doctor() {
  local rc=0
  echo "== Backend echo self-check =="

  _backend_check() {
    local name="$1"; shift
    if ! command -v "$1" >/dev/null 2>&1; then
      printf "  ✗ %-10s %s not found\n" "$name" "$1"
      rc=2; return
    fi
    local out
    out=$(HARNESS_MOCK_ADAPTER=0 timeout 30 "$@" 2>&1) || {
      printf "  ✗ %-10s call failed (rc=$?)\n" "$name"
      echo "      $(printf '%s' "$out" | head -1)" >&2
      rc=2; return
    }
    printf "  ✓ %-10s responded\n" "$name"
  }

  # claude：发送 "echo hi" 并取 .result
  if command -v claude >/dev/null 2>&1; then
    local out
    out=$(timeout 60 claude -p "say only the word: pong" --output-format json --max-turns 1 2>&1) && {
      local r; r=$(printf '%s' "$out" | jq -r '.result // empty' 2>/dev/null)
      if [[ -n "$r" ]]; then
        printf "  ✓ %-10s replied: %s\n" "claude" "$(echo "$r" | head -1 | cut -c1-40)"
      else
        printf "  ✗ %-10s no .result in output\n" "claude"
        rc=2
      fi
    } || { printf "  ✗ %-10s call failed\n" "claude"; rc=2; }
  else
    printf "  - %-10s not installed (skip)\n" "claude"
  fi

  # codex：发送一句话 + 取最后 agent_message
  if command -v codex >/dev/null 2>&1; then
    local out tmp
    tmp=$(mktemp -t cdx.XXXXXX)
    out=$(timeout 60 codex exec --json -s read-only --skip-git-repo-check --ephemeral \
          --dangerously-bypass-approvals-and-sandbox -o "$tmp" \
          "say only the word: pong" 2>&1) && {
      local r=""
      if [[ -f "$tmp" ]]; then r=$(head -c 80 "$tmp" | tr -d '\n'); fi
      [[ -z "$r" ]] && r=$(printf '%s' "$out" | jq -r 'select(.type=="item.completed" and .item.type=="agent_message") | .item.text' 2>/dev/null | tail -1 | head -c 80)
      if [[ -n "$r" ]]; then
        printf "  ✓ %-10s replied: %s\n" "codex" "$r"
      else
        printf "  ✗ %-10s no agent_message in output\n" "codex"
        rc=2
      fi
    } || { printf "  ✗ %-10s call failed\n" "codex"; rc=2; }
    rm -f "$tmp"
  else
    printf "  - %-10s not installed (skip)\n" "codex"
  fi

  # opencode：阶段三未实现
  command -v opencode >/dev/null 2>&1 \
    && printf "  - %-10s installed (adapter pending)\n" "opencode" \
    || printf "  - %-10s not installed (skip)\n" "opencode"

  echo
  [[ $rc -eq 0 ]] && echo "OK ✓" || echo "FAILED (rc=$rc)" >&2
  return $rc
}

# ── attach：attach 到执行平面 tmux session（worker 观测） ──
cmd_attach() {
  local cwd; cwd=$(pwd)
  [[ ! -f "$cwd/.harness/harness.db" ]] && { echo "not initialized" >&2; exit 1; }
  local hash; hash=$(printf '%s' "$cwd" | shasum -a 256 | cut -c1-8)

  local target="" path_only=0
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --path) path_only=1; shift ;;
      *)
        if [[ -z "$target" ]]; then target="$1"; shift
        else echo "unknown arg: $1" >&2; exit 1
        fi
        ;;
    esac
  done

  if [[ -z "$target" ]]; then
    # 默认 attach 到协调者 tmux 会话
    local session="harness-$hash"
    if tmux has-session -t "$session" 2>/dev/null; then
      exec tmux attach -t "$session"
    else
      echo "no coordinator session (run harness-infi first)" >&2
      exit 1
    fi
  fi

  # worker 模式：阶段四 worker 是 Python 线程，不是独立进程/pane。
  # 这里给"看现场"快照：status.json + guidance + worktree 路径 + 最近一次 adapter 调用。
  local wdir="$cwd/.harness/workers/$target"
  local sjson="$wdir/status.json"
  if [[ ! -f "$sjson" ]]; then
    echo "no such worker: $target (no $sjson)" >&2
    exit 1
  fi

  local tid stat branch progress sid updated backend
  tid=$(jq -r '.task_id // "-"'     "$sjson")
  stat=$(jq -r '.status // "-"'      "$sjson")
  branch=$(jq -r '.branch // "-"'    "$sjson")
  progress=$(jq -r '.progress // "-"' "$sjson")
  sid=$(jq -r '.session_id // "-"'   "$sjson")
  updated=$(jq -r '.updated // "-"'  "$sjson")
  backend=$(jq -r '.backend // "-"'  "$sjson")

  local proj_name; proj_name=$(basename "$cwd")
  local wt="$(dirname "$cwd")/.worktrees/$proj_name/$tid"

  if [[ $path_only -eq 1 ]]; then
    # 仅打印 worktree 路径，便于 cd "$(harness attach <wid> --path)"
    [[ -d "$wt" ]] && printf '%s\n' "$wt" && return 0
    echo "worktree gone: $wt" >&2; exit 2
  fi

  printf "Worker   : %s\n" "$target"
  printf "Backend  : %s\n" "$backend"
  printf "Task     : %s\n" "$tid"
  printf "Status   : %s\n" "$stat"
  printf "Branch   : %s\n" "$branch"
  printf "Progress : %s\n" "$progress"
  printf "Session  : %s\n" "$sid"
  printf "Updated  : %s\n" "$updated"
  if [[ -d "$wt" ]]; then
    printf "Worktree : %s\n" "$wt"
  else
    printf "Worktree : (gone)\n"
  fi

  local g="$wdir/guidance.json"
  if [[ -f "$g" ]]; then
    echo
    echo "== Guidance (blocking) =="
    jq -r '"question: " + (.question // "-") + "\ncontext : " + (.context // "-")' "$g"
  fi

  local last_log; last_log=$(ls -t "$cwd/.harness/logs/raw/"*"$tid"*.json 2>/dev/null | head -1)
  if [[ -n "$last_log" ]]; then
    echo
    echo "== Last adapter call =="
    jq -r '"ts      : " + .ts + "\nbackend : " + .backend +
           "\nresult  : " + ((.response.result // .response.error // "?") | tostring | .[0:200])' \
       "$last_log" 2>/dev/null || echo "(unparseable)"
  fi
}

cmd_upgrade() {
  # 找到 install.sh：HARNESS_HOME 指源码根
  local src="$HARNESS_HOME"
  if [[ ! -f "$src/install.sh" ]]; then
    echo "error: 找不到 install.sh（HARNESS_HOME=$src）" >&2
    echo "       手动跑：cd \$HOME/.harness && bash install.sh --upgrade" >&2
    exit 1
  fi
  exec bash "$src/install.sh" --upgrade "$@"
}

cmd_events() {
  local cwd; cwd=$(pwd)
  export HARNESS_DB="$cwd/.harness/harness.db"
  [[ ! -f "$HARNESS_DB" ]] && { echo "not initialized" >&2; exit 1; }

  local sub="${1:-pending}"; shift || true
  case "$sub" in
    pending|list)
      printf "  %-4s %-21s %-16s %-12s %s\n" "ID" "TIMESTAMP" "TYPE" "TASK" "PAYLOAD"
      _db event-pending | while IFS=$'\t' read -r eid ts etype tid payload; do
        # payload 截短到 60 字符方便扫
        local payload_trim; payload_trim=$(printf '%s' "$payload" | cut -c1-60)
        printf "  %-4s %-21s %-16s %-12s %s\n" "$eid" "$ts" "$etype" "${tid:--}" "$payload_trim"
      done
      ;;
    ack)
      local n=0
      for eid in "$@"; do
        _db event-ack "$eid" && n=$((n+1))
      done
      echo "acked $n event(s)"
      ;;
    *)
      echo "usage: harness events [pending|ack <eid>...]" >&2
      exit 1
      ;;
  esac
}

cmd_orphans() {
  # 列出当前孤儿任务（working/dispatched/gating 且超过阈值未更新）。
  # 协调者可用此命令检测 + 自动重试。
  # 用法：harness orphans [threshold_minutes]  默认 5 分钟
  local cwd; cwd=$(pwd)
  local HARNESS_DB_PATH="$cwd/.harness/harness.db"
  [[ ! -f "$HARNESS_DB_PATH" ]] && { echo "not initialized" >&2; exit 1; }
  export HARNESS_DB="$HARNESS_DB_PATH"
  local threshold="${1:-5}"
  _db query-orphans "$threshold" | while IFS=$'\t' read -r tid stat retries reds updated; do
    printf "%s\tstatus=%s\tretries=%s\tupdated=%s\n" \
      "${tid:--}" "${stat:--}" "${retries:--}" "${updated:--}"
  done
}

cmd_watchdog_tick() {
  # Run one watchdog cycle. Useful for manual testing / debugging the daemon.
  # The long-running loop lives in bin/harness-watchdog.
  local cwd; cwd=$(pwd)
  [[ ! -f "$cwd/.harness/harness.db" ]] && { echo "not initialized" >&2; exit 1; }
  export HARNESS_DB="$cwd/.harness/harness.db"
  "$HARNESS_PYTHON" -m harness.cli.watchdog
}

cmd_watch_panel() {
  # Live status panel in the bottom split-pane. Fast + silent on any error.
  local cwd; cwd=$(pwd)
  export HARNESS_DB="$cwd/.harness/harness.db"
  local W; W=$(tput cols 2>/dev/null || echo 80)
  local H; H=$(tput lines 2>/dev/null || echo 10)
  local CYAN='\033[36m' YLW='\033[33m' GRY='\033[90m' MAG='\033[35m'
  local GRN='\033[32m'  RED='\033[31m' DIM='\033[2m'  BLD='\033[1m' R='\033[0m'

  # Cap visible task rows to what fits the pane. Reserve lines for header (2)
  # + potential alert (2) + truncation indicator (1). Use static range guard.
  local row_cap=$(( H - 5 ))
  (( row_cap < 1 ))  && row_cap=1
  (( row_cap > 12 )) && row_cap=12

  # ── header: cost left-aligned, nav hint right-aligned ─────
  local cost_str="$0.00"
  [[ -f "$HARNESS_DB" ]] && {
    local c; c=$(_db today-cost 2>/dev/null) \
      && cost_str="$(printf '$%.2f' "$c")"
  }
  local nav="[Ctrl-B 0/1/2: chat/logs/watchdog]"
  local gap=$(( W - ${#cost_str} - ${#nav} - 5 ))   # 5 = "🫏  " visual width
  (( gap < 1 )) && gap=1
  printf "🫏  %s%*s%s\n" "$cost_str" "$gap" "" "$nav"
  printf "${DIM}%${W}s${R}\n" '' | tr ' ' '─'

  # ── body ──────────────────────────────────────────────────
  if [[ ! -f "$HARNESS_DB" ]]; then
    printf "\n  ${DIM}initializing…${R}\n"
    return 0
  fi

  # ── attention alerts (checked before task list) ───────────
  # Pending events the coordinator hasn't consumed yet
  local pending_events
  pending_events=$(_db event-pending 2>/dev/null | wc -l | tr -d ' ')
  # Queued tasks permanently blocked by a failed dependency
  local stuck_ids stuck_count
  stuck_ids=$(_db stuck-queued 2>/dev/null)
  stuck_count=$(printf '%s' "$stuck_ids" | grep -c . 2>/dev/null || echo 0)

  if (( pending_events > 0 || stuck_count > 0 )); then
    printf "\n"
    if (( stuck_count > 0 )); then
      local failed_dep
      failed_dep=$(_db blocking-failed 2>/dev/null | head -1)
      [[ -z "$failed_dep" ]] && failed_dep="?"
      printf "  ${RED}${BLD}⚠  STUCK${R}${RED}  %d task(s) blocked — %s failed${R}\n" \
        "$stuck_count" "$failed_dep"
      printf "  ${YLW}↑ tell Claude above — it will handle this automatically${R}\n"
    elif (( pending_events > 0 )); then
      printf "  ${YLW}${BLD}●  %d event(s) pending${R}${YLW} — say anything to Claude ↑${R}\n" \
        "$pending_events"
    fi
    printf "\n"
  fi

  local total_tasks; total_tasks=$(_db query-status 2>/dev/null | wc -l | tr -d ' ')
  local count=0
  _db query-status 2>/dev/null | while IFS=$'\t' read -r id stat _wid _branch retries _r _p _ts; do
    local icon col
    case "$stat" in
      working)    icon="⚙ working "; col="$CYAN" ;;
      gating)     icon="🔍 gating  "; col="$YLW"  ;;
      queued)     icon="○ queued  "; col="$GRY"  ;;
      dispatched) icon="▶ sent    "; col="$YLW"  ;;
      blocked)    icon="⏸ blocked "; col="$MAG"  ;;
      merged)     icon="✓ merged  "; col="$GRN"  ;;
      failed)     icon="✗ failed  "; col="$RED"  ;;
      *)          icon="  $stat   "; col=""       ;;
    esac
    # Title: skip YAML frontmatter (--- ... ---) and pick the first '# ' heading.
    # Falls back to the task ID when no heading is found. Previous head-1 logic
    # surfaced '---' as the title for any spec with frontmatter (the default
    # template includes `max_turns:`, so this bit virtually every new spec).
    local title="$id"
    local spec="$cwd/specs/${id}.md"
    if [[ -f "$spec" ]]; then
      local _t
      _t=$(awk '
        NR==1 && /^---$/ { fm=1; next }
        fm==1 && /^---$/ { fm=0; next }
        fm==1 { next }
        /^# / { sub(/^# +/, ""); print; exit }
      ' "$spec" 2>/dev/null | cut -c1-45)
      [[ -n "$_t" ]] && title="$_t"
    fi
    local retry_tag=""
    (( retries > 0 )) 2>/dev/null && retry_tag=" retry:$retries"
    printf "  ${col}%s${R} ${DIM}%s${R}%s\n" "$icon" "$title" "$retry_tag"
    count=$((count + 1))
    [[ $count -ge $row_cap ]] && break
  done

  # If we clipped some, tell the user explicitly — otherwise it's confusing
  # to see e.g. Q:2 in the header but only one queued row.
  if (( total_tasks > row_cap )); then
    printf "  ${DIM}… +%d more (run 'harness status' for full list)${R}\n" \
      "$(( total_tasks - row_cap ))"
  fi

  # ── empty state: show idea snippet or call-to-action ──────
  # Note: $count lives in the pipeline subshell and doesn't propagate back;
  # use $total_tasks (set via command substitution before the pipe) instead.
  if [[ $total_tasks -eq 0 ]]; then
    printf "\n"
    if [[ -f "$cwd/specs/initial.md" ]]; then
      local idea
      idea=$(grep -Ev '^#|^---|^$|^\*' "$cwd/specs/initial.md" 2>/dev/null \
             | head -1 | cut -c1-$(( W - 14 )))
      printf "  ${DIM}💡 idea:${R}  %s\n" "$idea"
      printf "\n"
      printf "  ${GRN}↑ say hi to Claude above to get started${R}\n"
    else
      printf "  ${DIM}↑ tell Claude what you want to build${R}\n"
    fi
  fi

  # ── coordinator last action (bottom strip) ────────────────
  local act_log="$cwd/.harness/logs/coordinator-activity.log"
  if [[ -f "$act_log" ]]; then
    local last_line ts_str ts_epoch now_epoch age_s act_text
    last_line=$(tail -1 "$act_log" 2>/dev/null)
    if [[ -n "$last_line" ]]; then
      ts_str=$(awk '{print $1}' <<< "$last_line")
      ts_epoch=$(date -j -u -f "%Y-%m-%dT%H:%M:%SZ" "$ts_str" +%s 2>/dev/null || echo 0)
      now_epoch=$(date +%s)
      age_s=$(( now_epoch - ts_epoch ))
      if (( age_s < 3600 )); then  # show entries within the last hour
        act_text=$(cut -c22- <<< "$last_line" | cut -c1-$(( W - 8 )))
        printf "${DIM}%${W}s${R}\n" '' | tr ' ' '─'
        printf "  ${DIM}🤖 %s${R}\n" "$act_text"
      fi
    fi
  fi
}

cmd_statusline() {
  # Claude Code 在协调者 .claude/settings.json 里把 statusLine.command 指到这里。
  # 每个 refreshInterval 调一次：stdin 收 JSON blob → stdout 一行 ANSI。
  # 逻辑全在 Python 模块（一次进程启动读完所有 DB / 文件，避免 bash 多次起 python）。
  exec "$HARNESS_PYTHON" -m harness.cli.statusline "$@"
}

cmd_help() {
  # 'EOF' 单引号关闭变量/命令替换 —— help 文本里有 $(harness ...) 示例，
  # 不引号会被 bash 当命令执行（一直 stderr 报 "harness: command not found"）
  cat <<'EOF'
🫏 harness-donk — 多 Agent 自驱动编码 Harness

Commands:
  init                    在当前 git repo 初始化 harness
  setup                   一次性环境校验 + 建 ~/.config/harness/
  doctor                  各 backend echo 自检（会真调一次 claude，烧少量 API）
  status [--task T-XXX [--history]]
                          任务列表 / 单任务详情 / 迁移史
  events pending          列出待处理事件（needs_decision / failed / completed / budget_exceeded）
  events ack <eid>...     标记事件已交付（避免协调者重复报告）
  orphans [minutes]       列出孤儿任务（working/dispatched/gating 超过 N 分钟无更新，默认 5）
  watchdog-tick           手动跑一次 watchdog 巡检（检测 orchestrator_down /
                          persistent_stuck / events_pending 并按需 notify）
  backup                  sqlite3 .backup 落到 .harness/backups/
  run-once [--mock]       跑一轮编排器（处理一个任务后退出）
  attach                  attach 到协调者 tmux 会话（无参）
  attach <wid> [--path]   worker 现场快照（worker 是 Python 线程，非独立 pane）；
                          --path 仅打印 worktree 路径，便于 cd "$(harness attach w1 --path)"
  upgrade                 拉最新源码 + uv sync + 重做符号链接（git pull --ff-only）
  statusline              Claude Code statusline 渲染器（接 stdin JSON，输出一行 ANSI）；
                          一般不直接调，由协调者 .claude/settings.json 自动调用
  help                    本帮助

Coordinator entry: harness-infi   (启动协调者对话面)
Coordinator tool:  harness-task   (在协调者 PATH 中)
EOF
}

case "$cmd" in
  init) cmd_init "$@" ;;
  setup) cmd_setup "$@" ;;
  doctor) cmd_doctor "$@" ;;
  status) cmd_status "$@" ;;
  events) cmd_events "$@" ;;
  orphans) cmd_orphans "$@" ;;
  watchdog-tick) cmd_watchdog_tick "$@" ;;
  backup) cmd_backup "$@" ;;
  run-once) cmd_run_once "$@" ;;
  attach) cmd_attach "$@" ;;
  upgrade) cmd_upgrade "$@" ;;
  watch-panel) cmd_watch_panel "$@" ;;
  statusline) cmd_statusline "$@" ;;
  help|-h|--help|"") cmd_help ;;
  *) echo "unknown command: $cmd" >&2; cmd_help; exit 1 ;;
esac
